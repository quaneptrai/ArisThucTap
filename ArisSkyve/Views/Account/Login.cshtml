@model ArisSkyve.Application.Dtos.LoginDto
@{
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
    ViewData["Title"] = "Sign in";
}

<div class="container vh-100 d-flex justify-content-center align-items-center">
    <div class="col-md-4">

        <h2 class="text-center mb-4">Log in to Aris</h2>

        <!-- SOCIAL LOGIN -->
        <a asp-controller="Account" asp-action="GoogleLogin"
           class="btn btn-outline-dark w-100 mb-3 d-flex align-items-center justify-content-center gap-2 py-2">
            <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" width="18">
            Continue with Google
        </a>

        <a asp-controller="Account" asp-action="FacebookLogin"
           class="btn btn-outline-dark w-100 mb-3 d-flex align-items-center justify-content-center gap-2 py-2">
            <img src="https://upload.wikimedia.org/wikipedia/commons/5/51/Facebook_f_logo_%282019%29.svg" width="18">
            Continue with Facebook
        </a>

        <p class="text-center text-muted my-3">or</p>

        <!-- FORM -->
        <form asp-action="Login" method="post">
            <!-- EMAIL -->
            <div class="mb-3">
                <label class="form-label">Email</label>
                <input asp-for="Email" class="form-control" placeholder="Enter email">
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <!-- PASSWORD -->
            <div class="mb-3">
                <label class="form-label">Password</label>
                <input asp-for="Password" type="password" class="form-control" placeholder="Enter password">
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <!-- BUTTON -->
            <button type="submit" class="btn btn-dark w-100 py-2">
                Log in
            </button>

            <!-- LINKS -->
            <div class="text-center mt-3">
                <a asp-action="ResetPassword">Reset password</a>
            </div>

            <div class="text-center mt-2">
                <span>No account?</span>
                <a asp-action="Register" class="fw-semibold">Create one</a>
            </div>

        </form>
    </div>
</div>