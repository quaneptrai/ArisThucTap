    @model ArisSkyve.Domain.Entities.User
    @{
        Layout = "~/Views/Shared/_AuthLayout.cshtml";
        ViewData["Title"] = "Sign in";
    }

    <div class="container vh-100 d-flex justify-content-center align-items-center">
        <div class="col-md-3">
            <h2 class="text-center mb-4">Log in to Aris</h2>
            <a asp-controller="Account"
               asp-action="GoogleLogin"
               class="singinGoogle text-decoration-none text-black mb-4 btn-light border w-100 d-flex align-items-center justify-content-center gap-2 border border-black rounded p-3">

                <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" width="20">

                Continue with Google
            </a>
            <a asp-controller="Account" asp-action="FacebookLogin" class="singinGoogle text-decoration-none text-black mb-4 btn-light border w-100 d-flex align-items-center justify-content-center gap-2 border border-black rounded p-3">
                <img src="https://upload.wikimedia.org/wikipedia/commons/5/51/Facebook_f_logo_%282019%29.svg" width="20">
                Continue with Facebook
            </a>
            <p class="text-center text-muted my-2">or</p>
            <form asp-action="Login" method="post">
                <div class="form-floating mb-3">
                    <input asp-for="Email" class="form-control bg-light" placeholder="Email">
                    <label asp-for="Email"></label>
                </div>

                <div class="form-floating mb-3 ">
                    <input asp-for="PasswordHash" type="password" class="form-control bg-light" placeholder="Password">
                    <label>Password</label>
                </div>
                <button asp-action="login" type="submit" class="btn btn-dark w-100 py-3 login-btn">
                    <span class="arrow">→</span>
                    <span class="text">Log in</span>
                </button>
                <div class="d-flex flex-column align-items-center mt-3 gap-2">

                    <div class="d-flex gap-3">
                        <a class="text-decoration-none" asp-controller="Account" asp-action="SingleSignIn">
                            Use single sign in
                        </a>

                        <a class="text-decoration-none" asp-controller="Account" asp-action="ResetPassword">
                            Reset password
                        </a>
                    </div>

                    <div>
                        <span>No account?</span>
                        <a class="text-decoration-none fw-semibold" asp-controller="Account" asp-action="Register">
                            Create one
                        </a>
                    </div>
                </div>
            </form> 
        </div>
    </div>