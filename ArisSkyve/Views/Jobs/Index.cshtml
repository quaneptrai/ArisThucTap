@{
    Layout = null;
}
<!DOCTYPE html>
    <html>
    <head>
     <title>Jobs</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
        <style>
            body {
                background: #f4f6fb;
            }

            .custom-nav {
                padding-left: 6px !important;
                padding-right: 6px !important;
            }

            .navbar {
                min-height: 45px;
                padding: 4px 0;
                background: linear-gradient(90deg,#1e88e5,#42a5f5);
            }

            /* logo */
            .logo {
                font-weight: 700;
                font-size: 22px;
                color: white;
                text-decoration: none;
            }

            .SearchContainer {
                display: flex;
                align-items: center;
                position: relative;
                width: 40px;
                height: 40px;
                border-radius: 50px;
                background: white;
                transition: all 0.35s ease;
                overflow: hidden;
                cursor: pointer;
            }

            .SearchContainer i {
                position: absolute;
                left: 12px;
                font-size: 16px;
                color: #777;
            }

            .search-input {
                border: none;
                outline: none;
                width: 0;
                opacity: 0;
                padding-left: 35px;
                transition: all 0.35s ease;
                background: transparent;
            }

            .SearchContainer:hover {
                width: 220px;
                border-radius: 25px;
            }

            .SearchContainer:hover .search-input {
                width: 100%;
                opacity: 1;
            }

            .navbar-nav {
                display: flex;
                align-items: center;
            }

            .navbar .nav-item {
                border-radius: 10px;
                transition: 0.2s;
                margin: 0 4px;
            }

            .navbar .nav-item:hover {
                background: rgba(255,255,255,0.15);
            }

            .navbar .nav-item.active {
                background: rgba(255,255,255,0.25);
            }

            .navbar .nav-link {
                position: relative;
                padding: 6px 12px;
            }

            .navbar .nav-link i {
                font-size: 14px;
            }

            .navbar .nav-link span {
                font-size: 11px;
            }

            /* underline animation */
            .navbar .nav-link::after {
                content: "";
                position: absolute;
                left: 50%;
                bottom: 0;
                width: 0;
                height: 3px;
                background: white;
                transition: 0.25s;
                transform: translateX(-50%);
            }

            .navbar .nav-link:hover::after {
                width: 60%;
            }

            .navbar .nav-link.active::after {
                width: 100%;
            }
        </style>
    </head>
    <body>
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container-fluid px-2 d-flex justify-content-between custom-nav">

            <!-- Logo -->
            <a class="logo" asp-controller="Dashboard" asp-action="Index">Aris</a>

            <!-- Search -->
            <div class="SearchContainer ms-3">
                <i class="bi bi-search"></i>
                <input class="form-control search-input" placeholder="Search...">
            </div>

            <!-- Menu -->
            <ul class="navbar-nav ms-auto d-flex align-items-center">

                <li class="nav-item">
                    <a asp-controller="Dashboard" asp-action="Index" class="nav-link text-light d-flex flex-column align-items-center">
                        <i class="bi bi-house"></i>
                        <span>Home</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link text-light d-flex flex-column align-items-center">
                        <i class="bi bi-people"></i>
                        <span>Network</span>
                    </a>
                </li>

                <li class="nav-item active">
                    <a class="nav-link text-light d-flex flex-column align-items-center">
                        <i class="bi bi-briefcase"></i>
                        <span>Jobs</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link text-light d-flex flex-column align-items-center">
                        <i class="bi bi-bell"></i>
                        <span>Notifications</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link text-light d-flex flex-column align-items-center">
                        <i class="bi bi-gear"></i>
                        <span>Settings</span>
                    </a>
                </li>

                <!-- Avatar dropdown -->
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle text-light d-flex flex-column align-items-center"
                       href="#" data-bs-toggle="dropdown">

                        <img src="https://i.pravatar.cc/100"
                             class="rounded-circle"
                             width="30"
                             height="30" />

                        <span>Me</span>
                    </a>

                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item" href="#">Profile</a></li>
                        <li><a class="dropdown-item" href="#">Settings</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <button class="dropdown-item text-danger">Logout</button>
                        </li>
                    </ul>
                </li>

            </ul>
        </div>
    </nav>
    <div class="container-fluid mt-4">
        <div class="row g-3">

            <!-- LEFT SIDEBAR -->
            <div class="col-lg-3 ms-3">

                <div class="card">
                    <div class="profile-cover"></div>
                    <div class="card-body text-center">
                        <a asp-controller="Profile" asp-action="Index">
                            <img src="https://i.pravatar.cc/100" class="avatar">
                        </a>
                        <h6 class="mt-2 mb-0">@Model.Username</h6>
                        <div class="text-center d-flex flex-column align-items-start ms-2">
                            <small class="text-muted mb-1" style="color:black !important">@Model.Profile.Bio</small>
                            <small class="text-muted mb-1" style="color:black !important">
                                @if (Model.Profile.isStudent)
                                {
                                    <span>🎓 Student at @Model.Profile.Education.School</span>
                                }
                                else
                                {
                                    <span>💼 @Model.Profile.JobTitle</span>
                                }
                            </small>
                            <small class="text-muted">@Model.Profile.Location</small>
                        </div>
                    </div>
                </div>


            </div>

            <!-- CENTER FEED -->
            <div class="col-lg-6">

               
            </div>
          

        </div>
    </body>
    </html>