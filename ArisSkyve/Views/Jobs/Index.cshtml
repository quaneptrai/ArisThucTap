    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
                    $(document).ready(function () {
            // --- 1. BIẾN TOÀN CỤC ---
            let currentTopK = 3;
            const aiContent = $("#ai-content-area");
            const loadMoreAiBtn = $("#load-more-ai");

            // --- 2. XỬ LÝ NÂNG CẤP ACCOUNT (BUSINESS) ---
            $('#agreeTerms').on('change', function() {
                $('#btnSubmitUpgrade').prop('disabled', !$(this).is(':checked'));
            });

            $('#upgradeBusinessForm').on('submit', function (e) {
                e.preventDefault();
                const btn = $('#btnSubmitUpgrade');
                const originalText = btn.html();
                btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-2"></span> Đang xử lý...');

                $.ajax({
                    url: '/Account/UpgradeToBusiness',
                    type: 'POST',
                    data: $(this).serialize(),
                    success: function (res) {
                        if (res.success) { alert("Nâng cấp thành công!"); location.reload(); }
                        else { alert("Lỗi: " + res.message); btn.prop('disabled', false).html(originalText); }
                    },
                    error: function () { alert("Lỗi kết nối."); btn.prop('disabled', false).html(originalText); }
                });
            });

            // --- 3. XỬ LÝ UPLOAD JSON & ĐĂNG TIN ---
            $('#jsonUpload').on('change', function(e) {
                const file = e.target.files[0];
                if (!file) return;
                const reader = new FileReader();
                reader.onload = function(e) {
                    try {
                        const data = JSON.parse(e.target.result);
                        $('#jobTitle').val(data.Title || "");
                        $('#jobCompany').val(data.Company || "");
                        $('#jobSalary').val(data.Salary || "");
                        $('#jobCate').val(data.cate || "");
                        $('#jobDeadline').val(data.Deadline || "");
                        $('#jobExperience').val(data.Experience || "");
                        $('#jobOriginalUrl').val(data.OriginalUrl || data.URL || "");
                        if (Array.isArray(data.Responsibilities)) $('#jobResponsibilities').val(data.Responsibilities.join('\n'));
                        if (Array.isArray(data.Requirements)) $('#jobRequirements').val(data.Requirements.join('\n'));
                        if (Array.isArray(data.Locations)) $('#jobLocations').val(data.Locations.join('\n'));
                        $('#jobFullText').val(data.FullText || "");
                        alert("🚀 Đã nạp dữ liệu JSON!");
                    } catch (err) { alert("Lỗi định dạng JSON."); }
                };
                reader.readAsText(file);
            });

            $('#createJobForm').on('submit', function (e) {
                e.preventDefault();
                const btn = $(this).find('button[type="submit"]');
                btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-2"></span> Đang gửi...');

                const jobData = {
                    Title: $('#jobTitle').val(),
                    Company: $('#jobCompany').val(),
                    Responsibilities: $('#jobResponsibilities').val().split('\n').filter(x => x.trim()),
                    Requirements: $('#jobRequirements').val().split('\n').filter(x => x.trim()),
                    Benefits: [],
                    WorkTime: ["Toàn thời gian"],
                    Salary: $('#jobSalary').val(),
                    Experience: $('#jobExperience').val(),
                    Deadline: $('#jobDeadline').val(),
                    cate: $('#jobCate').val(),
                    keywords: [],
                    Location_tags: [$('#jobCate').val()], // Demo tag
                    FullText: $('#jobFullText').val() || $('#jobTitle').val(),
                    OriginalUrl: $('#jobOriginalUrl').val(),
                    Locations: $('#jobLocations').val().split('\n').filter(x => x.trim())
                };

                $.ajax({
                    url: 'http://localhost:8001/jobposting', // Địa chỉ Python API của bạn
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify([jobData]),
                    success: function (res) {
                        alert("Thành công: " + res.message);
                        $('#postJobModal').modal('hide');
                        location.reload();
                    },
                    error: function (xhr) { alert("Lỗi API: " + (xhr.responseJSON?.detail || "Error")); },
                    complete: function() { btn.prop('disabled', false).html('Gửi dữ liệu <i class="bi bi-cloud-arrow-up-fill ms-2"></i>'); }
                });
            });

            // --- 4. XỬ LÝ GỢI Ý AI ---
            function loadAiJobs(count, isLoadMore = false) {
                if (!isLoadMore) {
                    aiContent.html('<div class="text-center p-4"><div class="spinner-border text-primary mb-2"></div><p>Aris đang tìm việc cho bạn...</p></div>');
                } else {
                    loadMoreAiBtn.prop('disabled', true).text('Đang tải thêm...');
                }

                $.get("/Jobs/GetAiRecommendations", { topK: count })
                    .done(function (data) {
                        if (data && data.trim().length > 0) {
                            aiContent.html(data);
                            loadMoreAiBtn.show();
                        } else {
                            if (!isLoadMore) aiContent.html('<div class="text-center text-muted small">Chưa có gợi ý phù hợp.</div>');
                            loadMoreAiBtn.hide();
                        }
                    })
                    .fail(function () { aiContent.html('<div class="text-danger small text-center">Lỗi AI.</div>'); })
                    .always(function() {
                        loadMoreAiBtn.prop('disabled', false).text('Xem thêm gợi ý AI');
                    });
            }

            // Chạy lần đầu
            loadAiJobs(currentTopK);
            loadMoreAiBtn.click(function () {
                currentTopK += 3;
                loadAiJobs(currentTopK, true);
            });
        });
    </script>

    <div class="modal fade" id="postJobModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
                <div class="modal-header border-0 pb-0">
                    <h5 class="fw-bold"><i class="bi bi-rocket-takeoff-fill text-primary me-2"></i>Đăng tin tuyển dụng (AI Ready)</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="mb-4 p-3 border rounded-4 bg-light d-flex align-items-center justify-content-between" style="border: 2px dashed #dee2e6 !important;">
                        <div>
                            <h6 class="fw-bold mb-1">Cấu trúc dữ liệu thông minh</h6>
                            <p class="small text-muted mb-0">Tự động điền nhanh bằng file .json</p>
                        </div>
                        <label for="jsonUpload" class="btn btn-primary btn-sm rounded-pill px-3">
                            <i class="bi bi-upload me-1"></i> Upload JSON
                        </label>
                        <input type="file" id="jsonUpload" accept=".json" class="d-none">
                    </div>

                    <form id="createJobForm" novalidate>
                        <div class="row g-3">
                            <div class="col-md-8">
                                <label class="form-label small fw-bold">Tiêu đề công việc *</label>
                                <input type="text" class="form-control input-modern" name="Title" id="jobTitle" required>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small fw-bold">Lĩnh vực (cate) *</label>
                                <input type="text" class="form-control input-modern" name="cate" id="jobCate" placeholder="IT, Logistics...">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold">Công ty *</label>
                                <input type="text" class="form-control input-modern" name="Company" id="jobCompany" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold">Mức lương</label>
                                <input type="text" class="form-control input-modern" name="Salary" id="jobSalary">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold">Hạn cuối (Deadline)</label>
                                <input type="text" class="form-control input-modern" name="Deadline" id="jobDeadline" placeholder="dd/mm/yyyy">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold">Kinh nghiệm</label>
                                <input type="text" class="form-control input-modern" name="Experience" id="jobExperience">
                            </div>
                            <div class="col-12">
                                <label class="form-label small fw-bold">Địa điểm (Mỗi dòng một địa chỉ)</label>
                                <textarea class="form-control input-modern" id="jobLocations" rows="2" placeholder="Hà Nội: 123 Cầu Giấy..."></textarea>
                            </div>
                            <div class="col-12">
                                <label class="form-label small fw-bold">Trách nhiệm công việc (Mỗi dòng một ý)</label>
                                <textarea class="form-control input-modern" id="jobResponsibilities" rows="3"></textarea>
                            </div>
                            <div class="col-12">
                                <label class="form-label small fw-bold">Yêu cầu ứng viên</label>
                                <textarea class="form-control input-modern" id="jobRequirements" rows="3"></textarea>
                            </div>
                            <input type="hidden" id="jobFullText">
                            <input type="hidden" id="jobOriginalUrl">
                        </div>
                        <div class="mt-4">
                            <button type="submit" class="btn btn-primary w-100 py-3 fw-bold rounded-3 shadow-sm">
                                Gửi dữ liệu lên hệ thống <i class="bi bi-cloud-arrow-up-fill ms-2"></i>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>


    <div class="modal fade" id="upgradeModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 24px; overflow: hidden;">
                <div class="row g-0">
                    <div class="col-lg-4 d-none d-lg-block bg-dark p-5 text-white">
                        <div class="d-flex flex-column h-100">
                            <div class="mb-4">
                                <span class="badge bg-primary mb-2">ARIS BUSINESS</span>
                                <h3 class="fw-bold">Nâng cấp Chuyên nghiệp</h3>
                            </div>
                            <ul class="list-unstyled small opacity-75">
                                <li class="mb-3"><i class="bi bi-check-circle-fill text-success me-2"></i> Xuất hiện ưu tiên trên kết quả tìm kiếm</li>
                                <li class="mb-3"><i class="bi bi-check-circle-fill text-success me-2"></i> Mở khóa bộ lọc ứng viên nâng cao</li>
                                <li class="mb-3"><i class="bi bi-check-circle-fill text-success me-2"></i> Tích xanh xác minh doanh nghiệp</li>
                            </ul>
                            <div class="mt-auto pt-4 border-top border-secondary">
                                <p class="x-small mb-0">Hỗ trợ: support@aris.com</p>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-8 p-4 p-md-5">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h4 class="fw-bold mb-0">Thiết lập doanh nghiệp</h4>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>

                        <form id="upgradeBusinessForm">
                            <div class="row g-3">
                                <div class="col-12">
