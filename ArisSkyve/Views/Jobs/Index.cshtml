@model JobsIndexViewModel

@{
    Layout = null;
    var rand = new Random();
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Aris Jobs | Find Your Career</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <style>
        body {
            background: #f0f2f5;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        /* --- GIỮ NGUYÊN HEADER STYLE CỦA BẠN --- */
        .navbar {
            min-height: 45px;
            padding-top: 4px;
            padding-bottom: 4px;
            background: linear-gradient(90deg,#1e88e5,#42a5f5)
        }

            .navbar .nav-link {
                position: relative;
                padding: 6px 12px;
            }

        .navbar-nav {
            display: flex;
            align-items: center;
        }

        .navbar .nav-link i {
            font-size: 14px !important;
        }

        .navbar .nav-link span {
            font-size: 11px;
        }

        .navbar .nav-item {
            border-radius: 10px;
            transition: all 0.2s ease;
            margin: 0 4px;
        }

            .navbar .nav-item:hover {
                background: rgba(255,255,255,0.15);
            }

            .navbar .nav-item.active {
                background: rgba(255,255,255,0.25);
            }

        .navbar .nav-link.active {
            color: #fff !important;
            font-weight: 600;
        }

        .navbar .nav-link::after {
            content: "";
            position: absolute;
            left: 50%;
            bottom: 0;
            width: 0;
            height: 3px;
            background: white;
            transition: all 0.25s ease;
            transform: translateX(-50%);
        }

        .navbar .nav-link:hover::after {
            width: 60%;
        }

        .navbar .nav-link.active::after {
            width: 100%;
        }

        .logo {
            font-weight: 800;
            font-size: 24px;
            color: white;
            text-decoration: none;
            letter-spacing: 1px;
        }

        /* SEARCH BOX STYLE */
        .SearchContainer {
            display: flex;
            align-items: center;
            position: relative;
            width: 40px;
            height: 40px;
            border-radius: 50px;
            background: white;
            transition: all 0.35s ease;
            overflow: hidden;
            cursor: pointer;
        }

            .SearchContainer i {
                position: absolute;
                left: 12px;
                font-size: 16px;
                color: #777;
                pointer-events: none;
            }

        .search-input {
            border: none;
            outline: none;
            width: 0;
            opacity: 0;
            padding-left: 35px;
            transition: all 0.35s ease;
            background: transparent;
        }

        .SearchContainer:hover {
            width: 220px;
            border-radius: 25px;
        }

            .SearchContainer:hover .search-input {
                width: 100%;
                opacity: 1;
            }

        /* --- GIỮ NGUYÊN SIDEBAR STYLE --- */
        .card {
            border: none;
            border-radius: 12px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
            margin-bottom: 1rem;
        }

        .profile-cover {
            height: 60px;
            background: #0073b1;
            border-radius: 12px 12px 0 0;
        }

        .avatar {
            width: 72px;
            height: 72px;
            border: 3px solid white;
            margin-top: -36px;
            background: white;
        }

        .filter-section h6 {
            font-size: 0.85rem;
            font-weight: 700;
            color: #666;
            text-transform: uppercase;
            margin-bottom: 12px;
        }

        .filter-link {
            text-decoration: none;
            color: #444;
            font-size: 0.9rem;
            display: flex;
            justify-content: space-between;
            padding: 5px 0;
        }

            .filter-link:hover {
                color: #0073b1;
            }

        /* --- CẢI THIỆN JOB CARD UI --- */
        .job-card {
            transition: all 0.3s ease;
            border: 1px solid transparent;
            cursor: pointer;
        }

            .job-card:hover {
                transform: translateY(-3px);
                box-shadow: 0 10px 20px rgba(0,0,0,0.1);
                border-color: #42a5f5;
            }

        .job-icon-container {
            width: 56px;
            height: 56px;
            background: #eef3f8;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            color: #1e88e5;
        }

        .salary-badge {
            background: #e6f4ea;
            color: #1e7e34;
            font-weight: 600;
            padding: 4px 12px;
            border-radius: 50px;
            font-size: 0.8rem;
        }

        .location-badge {
            background: #f0f2f5;
            color: #666;
            padding: 4px 12px;
            border-radius: 50px;
            font-size: 0.8rem;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark sticky-top">
        <div class="container d-flex align-items-center">
            <a class="logo" asp-controller="Dashboard" asp-action="Index">Aris</a>
            <div class="SearchContainer ms-3 d-none d-md-flex">
                <i class="bi bi-search"></i>
                <input class="form-control search-input" placeholder="Search jobs...">
            </div>
            <ul class="navbar-nav ms-auto flex-row">
                <li class="nav-item mx-2"><a class="nav-link text-center"><i class="bi bi-house-door-fill d-block"></i><span>Home</span></a></li>
                <li class="nav-item mx-2 active"><a class="nav-link text-center active"><i class="bi bi-briefcase-fill d-block"></i><span>Jobs</span></a></li>
                <li class="nav-item mx-2"><a class="nav-link text-center"><i class="bi bi-chat-dots-fill d-block"></i><span>Messaging</span></a></li>
                <li class="nav-item mx-2"><a class="nav-link text-center"><i class="bi bi-bell-fill d-block"></i><span>Notif</span></a></li>
                <li class="nav-item dropdown ms-3">
                    <a class="nav-link dropdown-toggle d-flex align-items-center p-0" data-bs-toggle="dropdown">
                        <img src="https://ui-avatars.com/api/?name=@Model.User.Username" class="rounded-circle" width="32" height="32">
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end mt-2">
                        <li><a class="dropdown-item" href="#">View Profile</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item text-danger" href="#">Sign Out</a></li>
                    </ul>
                </li>
            </ul>
        </div>
    </nav>

    <div class="container mt-4">
        <div class="row g-4">
            <div class="col-lg-3">
                <div class="card">
                    <div class="profile-cover"></div>
                    <div class="card-body text-center pt-0">
                        <img src="https://ui-avatars.com/api/?name=@Model.User.Username" class="avatar rounded-circle mb-2">
                        <h6 class="mb-0 fw-bold">@Model.User.Username</h6>
                        <p class="text-muted small">Software Engineer</p>
                    </div>
                    <div class="card-footer bg-white border-top-0">
                        <div class="filter-section">
                            <h6>My Career</h6>
                            <a href="#" class="filter-link"><span><i class="bi bi-bookmark-fill me-2"></i>My Jobs</span> <span class="badge bg-light text-dark">5</span></a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="card p-3 mb-3 border-0">
                    <h5 class="fw-bold mb-0">Recommended for you</h5>
                    <small class="text-muted">Based on your profile and search history</small>
                </div>

                <div id="jobContainer">
                    @Html.Partial("_JobCardPartial", Model.JobPostings)
                </div>

                <div class="text-center my-4">
                    <button id="loadMoreBtn" class="btn btn-primary rounded-pill px-5 shadow-sm">
                        <span id="btnText">Show more jobs</span>
                        <span id="btnSpinner" class="spinner-border spinner-border-sm d-none"></span>
                    </button>
                </div>
            </div>

            <div class="col-lg-3">
                <div class="card p-3">
                    <h6 class="fw-bold mb-3">Hiring Now</h6>
                    <div class="d-flex align-items-start mb-3">
                        <div class="bg-light p-2 rounded me-2"><i class="bi bi-graph-up-arrow text-primary"></i></div>
                        <div>
                            <p class="mb-0 small fw-bold">Tech layoffs slowing down</p>
                            <small class="text-muted">4d ago • 1,240 readers</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let skip = @Model.JobPostings.Count;
        const take = 5;

        $("#loadMoreBtn").on("click", function() {
            const btn = $(this);
            $("#btnText").addClass("d-none");
            $("#btnSpinner").removeClass("d-none");

            $.get("/Jobs/GetJobs", { skip: skip, take: take }, function(data) {
                if (!data || data.success === false) {
                    btn.html("No more jobs").addClass("disabled");
                } else {
                    $("#jobContainer").append(data);
                    skip += take;
                }
                $("#btnText").removeClass("d-none");
                $("#btnSpinner").addClass("d-none");
            });
        });
    </script>
</body>
</html>