@using Newtonsoft.Json
@model ArisSkyve.Domain.Entities.JobPosting

@{
    Layout = null;
    var companyLogo = "https://ui-avatars.com/api/?name=" + Model.Company + "&background=0D6EFD&color=fff&size=128";

    // HÀM XỬ LÝ RÁC JSON
    List<string> ParseList(string data)
    {
        if (string.IsNullOrEmpty(data) || data == "[]") return new List<string>();
        try
        {
            return JsonConvert.DeserializeObject<List<string>>(data) ?? new List<string>();
        }
        catch
        {
            return new List<string> { data };
        }
    }

    var resList = ParseList(Model.Responsibilities);
    var reqList = ParseList(Model.Requirements);
    var benList = ParseList(Model.Benefits);
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@Model.Title - @Model.Company</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">

    <style>
        :root {
            --bg-color: #f8fafc;
            --primary-color: #2563eb;
            --text-main: #1e293b;
            --card-radius: 24px;
        }

        body {
            background-color: var(--bg-color);
            font-family: 'Inter', sans-serif;
            color: var(--text-main);
            padding-top: 100px;
            line-height: 1.7;
        }

        .job-detail-card {
            background: #ffffff;
            border-radius: var(--card-radius);
            border: 1px solid #e2e8f0;
            padding: 40px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        }

        .section-title {
            font-weight: 700;
            font-size: 1.25rem;
            margin-bottom: 1.5rem;
            color: #0f172a;
            border-left: 4px solid var(--primary-color);
            padding-left: 16px;
        }

        .content-area {
            color: #475569;
            font-size: 15px;
        }

        /* Style cho từng dòng sau khi bỏ rác JSON */
        .content-line {
            display: block;
            margin-bottom: 8px;
            position: relative;
            padding-left: 15px;
        }

            .content-line::before {
                content: "•";
                position: absolute;
                left: 0;
                color: var(--primary-color);
                font-weight: bold;
            }
        /* Style cho các dòng tiêu đề (có dấu :) */
        .content-header {
            display: block;
            font-weight: 700;
            color: #1e293b;
            margin-top: 15px;
            margin-bottom: 5px;
        }

        .meta-box {
            background: #f1f5f9;
            border-radius: 16px;
            padding: 24px;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 16px;
        }

        .btn-apply {
            background: var(--primary-color);
            border: none;
            padding: 16px;
            border-radius: 12px;
            font-weight: 700;
            width: 100%;
            transition: all 0.2s;
        }

            .btn-apply:hover {
                background: #1d4ed8;
                transform: translateY(-2px);
            }
    </style>
</head>
<body>

    <nav class="navbar fixed-top bg-white border-bottom py-3">
        <div class="container">
            <a href="/Jobs" class="fw-bold text-primary text-decoration-none fs-4">Aris</a>
            <a href="/Jobs" class="btn btn-light btn-sm rounded-pill">
                <i class="bi bi-arrow-left"></i> Quay lại
            </a>
        </div>
    </nav>

    <div class="container">
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="job-detail-card">
                    <div class="d-flex align-items-center gap-4 mb-4">
                        <img src="@companyLogo" class="rounded-4 border" style="width: 80px; height: 80px;" alt="logo">
                        <div>
                            <h1 class="fw-800 mb-1" style="font-size: 1.8rem;">@Model.Title</h1>
                            <div class="text-primary fw-600">@Model.Company</div>
                        </div>
                    </div>

                    <div class="meta-box mb-5">
                        <div>
                            <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 10px;">Mức lương</small>
                            <span class="fw-bold"><i class="bi bi-cash text-primary"></i> @(Model.Salary ?? "Thỏa thuận")</span>
                        </div>
                        <div>
                            <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 10px;">Kinh nghiệm</small>
                            <span class="fw-bold"><i class="bi bi-briefcase text-primary"></i> @(Model.Experience ?? "Không yêu cầu")</span>
                        </div>
                        <div>
                            <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 10px;">Hạn nộp</small>
                            <span class="fw-bold"><i class="bi bi-calendar-check text-primary"></i> @Model.Deadline?.ToString("dd/MM/yyyy")</span>
                        </div>
                    </div>

                    @* XỬ LÝ TRÁCH NHIỆM *@
                    <div class="mb-5">
                        <h4 class="section-title">Mô tả công việc</h4>
                        <div class="content-area">
                            @if (resList.Any())
                            {
                                foreach (var line in resList)
                                {
                                    if (line.Contains(":") && line.Length < 50)
                                    {
                                        <span class="content-header">@line</span>
                                    }
                                    else
                                    {
                                        <span class="content-line">@line</span>
                                    }
                                }
                            }
                            else
                            {
                                <span class="text-muted italic">Thông tin đang được cập nhật...</span>
                            }
                        </div>
                    </div>

                    @* XỬ LÝ YÊU CẦU *@
                    <div class="mb-5">
                        <h4 class="section-title">Yêu cầu ứng viên</h4>
                        <div class="content-area">
                            @if (reqList.Any())
                            {
                                foreach (var line in reqList)
                                {
                                    if (line.Contains(":") && line.Length < 50)
                                    {
                                        <span class="content-header">@line</span>
                                    }
                                    else
                                    {
                                        <span class="content-line">@line</span>
                                    }
                                }
                            }
                            else
                            {
                                <span class="text-muted italic">Thông tin đang được cập nhật...</span>
                            }
                        </div>
                    </div>

                    @* XỬ LÝ QUYỀN LỢI *@
                    <div class="mb-4">
                        <h4 class="section-title">Quyền lợi được hưởng</h4>
                        <div class="content-area">
                            @if (benList.Any())
                            {
                                foreach (var line in benList)
                                {
                                    if (line.Contains(":") && line.Length < 50)
                                    {
                                        <span class="content-header">@line</span>
                                    }
                                    else
                                    {
                                        <span class="content-line">@line</span>
                                    }
                                }
                            }
                            else
                            {
                                <span class="text-muted italic">Thông tin đang được cập nhật...</span>
                            }
                        </div>
                    </div>
                </div>
            </div>

            @* CỘT PHẢI - GIỮ NGUYÊN *@
            <div class="col-lg-4">
                <div class="sticky-top" style="top: 100px;">
                    <div class="card border-0 shadow-sm p-4 rounded-4 bg-white">
                        <h6 class="fw-bold mb-3">Sẵn sàng ứng tuyển?</h6>
                        <button class="btn btn-primary btn-apply text-white mb-3">ỨNG TUYỂN NGAY</button>
                        <button class="btn btn-outline-secondary w-100 rounded-3 py-2 fw-medium">
                            <i class="bi bi-heart me-1"></i> Lưu tin
                        </button>
                        <hr class="my-4">
                        <div class="small">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Ngày đăng:</span>
                                <span class="fw-medium">@Model.CreatedAt.ToString("dd/MM/yyyy")</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Hình thức:</span>
                                <span class="fw-medium">@Model.WorkTime</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <footer class="py-5 mt-5 text-center text-muted border-top bg-white">
        <p class="mb-0">© 2026 Aris Skyve - Nền tảng tuyển dụng thông minh</p>
    </footer>

</body>
</html>