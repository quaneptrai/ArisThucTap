@model ArisSkyve.Domain.Entities.JobPosting

@{
    Layout = null;
    var responsibilities = ViewBag.Responsibilities as List<string> ?? new List<string>();
    var requirements = ViewBag.Requirements as List<string> ?? new List<string>();
    var benefits = ViewBag.Benefits as List<string> ?? new List<string>();
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@Model.Title | @Model.Company</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <style>
        body {
            background: #f5f6fa;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .logo {
            font-weight: 700;
            font-size: 22px;
            color: white;
            text-decoration: none;
        }

        .navbar {
            min-height: 45px;
            padding-top: 4px;
            padding-bottom: 4px;
            background: linear-gradient(90deg,#1e88e5,#42a5f5)
        }

            .navbar .nav-link {
                position: relative;
                padding: 6px 12px;
            }

        .navbar-nav {
            display: flex;
            align-items: center;
        }

        .navbar .nav-link i {
            font-size: 14px !important;
        }

        .navbar .nav-link span {
            font-size: 11px;
        }

        .navbar .nav-item {
            border-radius: 10px;
            transition: all 0.2s ease;
            margin: 0 4px;
        }

            .navbar .nav-item:hover {
                background: rgba(255,255,255,0.15);
            }

            .navbar .nav-item.active {
                background: rgba(255,255,255,0.25);
            }

        .navbar .nav-link.active {
            color: #fff !important;
            font-weight: 600;
        }

        .navbar .nav-link::after {
            content: "";
            position: absolute;
            left: 50%;
            bottom: 0;
            width: 0;
            height: 3px;
            background: white;
            transition: all 0.25s ease;
            transform: translateX(-50%);
        }

        .navbar .nav-link:hover::after {
            width: 60%;
        }

        .navbar .nav-link.active::after {
            width: 100%;
        }

        .SearchContainer {
            display: flex;
            align-items: center;
            position: relative;
            width: 40px; /* nhỏ lại */
            height: 40px;
            border-radius: 50px;
            background: white;
            transition: all 0.35s ease;
            overflow: hidden;
            cursor: pointer;
        }

            /* icon */
            .SearchContainer i {
                position: absolute;
                left: 12px;
                font-size: 16px;
                color: #777;
                pointer-events: none;
            }

        /* input */
        .search-input {
            border: none;
            outline: none;
            width: 0;
            opacity: 0;
            padding-left: 35px;
            transition: all 0.35s ease;
            background: transparent;
        }

        /* hover -> expand */
        .SearchContainer:hover {
            width: 220px;
            border-radius: 25px;
        }

            /* khi expand thì input hiện ra */
            .SearchContainer:hover .search-input {
                width: 100%;
                opacity: 1;
            }
        /* JOB CARD DETAIL */
        .job-card {
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 6px 18px rgba(0,0,0,0.08);
            padding: 2rem;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

            .job-card:hover {
                transform: translateY(-3px);
                box-shadow: 0 10px 28px rgba(0,0,0,0.12);
            }

        .job-title {
            font-size: 1.75rem;
            font-weight: 700;
            margin-bottom: 0.3rem;
        }

        .company-name {
            font-size: 1.2rem;
            font-weight: 600;
            color: #0073b1;
            margin-bottom: 1rem;
        }

        .job-meta span {
            display: inline-block;
            margin-right: 1rem;
            font-size: 0.95rem;
            color: #555;
        }

        .job-section {
            margin-top: 1.5rem;
        }

            .job-section h5 {
                font-weight: 600;
                margin-bottom: 0.5rem;
                color: #333;
            }

            .job-section p {
                margin-bottom: 0.75rem;
                line-height: 1.6;
                white-space: pre-line; /* giữ dòng enter */
            }

        /* Badge benefits */
        .badge-benefit {
            display: inline-block;
            background: #e7f3ff;
            color: #0073b1;
            padding: 0.35rem 0.65rem;
            border-radius: 12px;
            margin-right: 0.5rem;
            margin-bottom: 0.5rem;
            font-size: 0.875rem;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

            .badge-benefit:hover {
                transform: translateY(-2px);
                box-shadow: 0 3px 6px rgba(0,0,0,0.15);
            }

        /* Sidebar */
        .sidebar-card {
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 6px 18px rgba(0,0,0,0.08);
            padding: 1.5rem;
            position: sticky;
            top: 80px;
        }

        .btn-apply {
            width: 100%;
            margin-bottom: 0.75rem;
        }

        /* Hover subtle animation */
        a.btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 12px rgba(0,0,0,0.12);
        }

        .job-tags span {
            background: #f0f4f8;
            color: #0073b1;
            padding: 0.35rem 0.65rem;
            border-radius: 12px;
            margin-right: 0.5rem;
            margin-bottom: 0.5rem;
            display: inline-block;
            font-size: 0.875rem;
        }
    </style>
</head>
<body>
    <!-- HEADER NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark sticky-top">
        <div class="container d-flex align-items-center">
            <a class="logo" asp-controller="Jobs" asp-action="Index">Aris</a>
            <div class="SearchContainer ms-3 d-none d-md-flex">
                <i class="bi bi-search"></i>
                <input class="form-control search-input" placeholder="Search jobs...">
            </div>
            <ul class="navbar-nav ms-auto flex-row">
                <li class="nav-item mx-2"><a asp-asp-controller="Dashboard" asp-action="Index" class="nav-link text-center"><i class="bi bi-house-door-fill d-block"></i><span>Home</span></a></li>
                <li class="nav-item mx-2 active"><a class="nav-link text-center active"><i class="bi bi-briefcase-fill d-block"></i><span>Jobs</span></a></li>
                <li class="nav-item mx-2"><a class="nav-link text-center"><i class="bi bi-chat-dots-fill d-block"></i><span>Messaging</span></a></li>
                <li class="nav-item mx-2"><a class="nav-link text-center"><i class="bi bi-bell-fill d-block"></i><span>Notif</span></a></li>
            </ul>
        </div>
    </nav>

    <div class="container mt-4">
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="job-card">
                    <div class="job-header">
                        <h1 class="job-title">@Model.Title</h1>
                        <small class="text-muted">@Model.CreatedAt.ToString("dd MMM yyyy")</small>
                    </div>
                    <div class="company-name">@Model.Company</div>

                    <div class="job-meta mt-3">
                        @if (!string.IsNullOrEmpty(Model.WorkTime))
                        {
                            <p><strong>Thời gian làm việc:</strong> @Model.WorkTime</p>
                        }
                        @if (!string.IsNullOrEmpty(Model.Salary))
                        {
                            <p><strong>Mức lương:</strong> @Model.Salary</p>
                        }
                        @if (!string.IsNullOrEmpty(Model.Experience))
                        {
                            <p><strong>Kinh nghiệm:</strong> @Model.Experience</p>
                        }
                        @if (Model.Deadline != null)
                        {
                            <p><strong>Hạn nộp hồ sơ:</strong> @Model.Deadline?.ToString("dd/MM/yyyy")</p>
                        }
                    </div>

                    @if (Model.Locations.Any())
                    {
                        <div class="job-tags mt-3">
                            @foreach (var loc in Model.Locations)
                            {
                                <span>@loc.City</span>
                            }
                        </div>
                    }

                    <div class="job-section">
                        <h5>
                            Mô tả công việc
                        </h5>
                        <p>@string.Join("\n", responsibilities)</p>
                    </div>

                    <div class="job-section">
                        <h5>Yêu cầu ứng viên</h5>
                        <p>@string.Join("\n", requirements)</p>
                    </div>

                    <div class="job-section">
                        <h5>Quyền lợi</h5>
                        <div>
                            @foreach (var b in benefits)
                            {
                                <span class="badge-benefit">@b</span>
                            }
                        </div>
                    </div>

                    @if (Model.BusinessAccount != null)
                    {
                        <div class="job-section">
                            <h5>Company Info</h5>
                            <p>@Model.BusinessAccount.FullName - @Model.BusinessAccount.Industry</p>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.OriginalUrl))
                    {
                        <a href="@Model.OriginalUrl" target="_blank" class="btn btn-primary btn-apply">View Original Job</a>
                    }
                </div>
            </div>

            <div class="col-lg-4">
                <div class="sidebar-card">
                    <a href="/Jobs" class="btn btn-outline-primary btn-apply">Xem những công việc khác</a>
                    <a href="#" class="btn btn-success btn-apply">Ứng tuyển ngay</a>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>