@model ArisSkyve.Domain.Entities.JobPosting

@{
    Layout = null;
    var responsibilities = ViewBag.Responsibilities as List<string> ?? new List<string>();
    var requirements = ViewBag.Requirements as List<string> ?? new List<string>();
    var benefits = ViewBag.Benefits as List<string> ?? new List<string>();
    // Mock logo cho "vibe" công nghệ
    var companyLogo = "https://ui-avatars.com/api/?name=" + Model.Company + "&background=0D6EFD&color=fff&size=128";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@Model.Title | Aris Jobs</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">

    <style>
        :root {
            --bg-color: #f3f4f6;
            --primary-color: #2563eb;
            --text-main: #1f2937;
            --text-muted: #6b7280;
            --card-radius: 20px;
            --nav-height: 68px;
        }

        body {
            background-color: var(--bg-color);
            font-family: 'Inter', sans-serif;
            color: var(--text-main);
            padding-top: calc(var(--nav-height) + 30px);
            line-height: 1.6;
        }

        /* --- NAVBAR --- */
        .navbar {
            height: var(--nav-height);
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid #e5e7eb;
            position: fixed;
            top: 0;
            width: 100%;
            z-index: 1000;
        }

        .logo {
            font-weight: 800;
            font-size: 26px;
            color: var(--primary-color);
            text-decoration: none;
            letter-spacing: -0.5px;
        }

        /* --- MAIN CONTENT --- */
        .job-detail-card {
            background: #ffffff;
            border-radius: var(--card-radius);
            border: 1px solid rgba(0,0,0,0.05);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
            overflow: hidden;
            padding: 40px;
        }

        .company-logo-lg {
            width: 80px;
            height: 80px;
            border-radius: 16px;
            object-fit: cover;
            border: 1px solid #f1f5f9;
        }

        .job-title {
            font-weight: 800;
            font-size: 2rem;
            color: #111827;
            letter-spacing: -0.02em;
        }

        .company-link {
            color: var(--primary-color);
            text-decoration: none;
            font-weight: 600;
            font-size: 1.1rem;
        }

        /* --- META INFO --- */
        .meta-box {
            background: #f8fafc;
            border-radius: 16px;
            padding: 20px;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 20px;
            margin: 30px 0;
        }

        .meta-item i {
            color: var(--primary-color);
            margin-right: 8px;
            font-size: 1.1rem;
        }

        .meta-label {
            font-size: 12px;
            color: var(--text-muted);
            text-transform: uppercase;
            font-weight: 700;
            display: block;
        }

        .meta-value {
            font-weight: 600;
            font-size: 14px;
            color: #334155;
        }

        /* --- SECTIONS --- */
        .section-title {
            font-weight: 700;
            font-size: 1.25rem;
            margin-bottom: 1.25rem;
            position: relative;
            padding-left: 15px;
        }

            .section-title::before {
                content: "";
                position: absolute;
                left: 0;
                top: 4px;
                bottom: 4px;
                width: 4px;
                background: var(--primary-color);
                border-radius: 10px;
            }

        .content-list {
            list-style: none;
            padding-left: 0;
        }

            .content-list li {
                position: relative;
                padding-left: 25px;
                margin-bottom: 12px;
                color: #4b5563;
            }

                .content-list li::before {
                    content: "→";
                    position: absolute;
                    left: 0;
                    color: var(--primary-color);
                    font-weight: bold;
                }

        /* --- BENEFIT TAGS --- */
        .benefit-tag {
            background: #eff6ff;
            color: #1d4ed8;
            padding: 8px 16px;
            border-radius: 50px;
            font-size: 13px;
            font-weight: 600;
            display: inline-block;
            margin: 0 8px 8px 0;
            border: 1px solid #dbeafe;
        }

        /* --- SIDEBAR --- */
        .sticky-sidebar {
            position: sticky;
            top: 100px;
        }

        .action-card {
            background: white;
            border-radius: var(--card-radius);
            padding: 24px;
            border: 1px solid rgba(0,0,0,0.05);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
        }

        .btn-apply-now {
            background: var(--primary-color);
            color: white;
            border-radius: 12px;
            padding: 14px;
            font-weight: 700;
            width: 100%;
            border: none;
            transition: 0.3s;
        }

            .btn-apply-now:hover {
                background: #1d4ed8;
                transform: translateY(-2px);
                box-shadow: 0 8px 20px rgba(37, 99, 235, 0.3);
                color: white;
            }

        .btn-secondary-custom {
            background: #f1f5f9;
            color: #475569;
            border-radius: 12px;
            padding: 12px;
            width: 100%;
            font-weight: 600;
            text-decoration: none;
            display: block;
            text-align: center;
            margin-top: 12px;
            transition: 0.2s;
        }

            .btn-secondary-custom:hover {
                background: #e2e8f0;
                color: #1e293b;
            }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg">
        <div class="container">
            <a asp-controller="Jobs" asp-action="Index" class="logo">Aris</a>
            <div class="ms-auto">
                <a asp-action="Index" class="text-muted text-decoration-none fw-medium small">
                    <i class="bi bi-arrow-left me-1"></i> Quay lại danh sách
                </a>
            </div>
        </div>
    </nav>

    <div class="container">
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="job-detail-card">
                    <div class="d-flex align-items-start gap-4 mb-4">
                        <img src="@companyLogo" class="company-logo-lg" alt="Logo">
                        <div>
                            <h1 class="job-title">@Model.Title</h1>
                            <a href="#" class="company-link">@Model.Company</a>
                            <div class="text-muted small mt-2">
                                <i class="bi bi-clock-history me-1"></i> Đăng ngày @Model.CreatedAt.ToString("dd/MM/yyyy")
                            </div>
                        </div>
                    </div>

                    <div class="meta-box">
                        <div class="meta-item">
                            <span class="meta-label">Mức lương</span>
                            <span class="meta-value"><i class="bi bi-cash-stack"></i> @(string.IsNullOrEmpty(Model.Salary) ? "Thỏa thuận" : Model.Salary)</span>
                        </div>
                        <div class="meta-item">
                            <span class="meta-label">Kinh nghiệm</span>
                            <span class="meta-value"><i class="bi bi-mortarboard"></i> @(string.IsNullOrEmpty(Model.Experience) ? "Không yêu cầu" : Model.Experience)</span>
                        </div>
                        <div class="meta-item">
                            <span class="meta-label">Hạn nộp</span>
                            <span class="meta-value"><i class="bi bi-calendar-event"></i> @Model.Deadline?.ToString("dd/MM/yyyy")</span>
                        </div>
                        <div class="meta-item">
                            <span class="meta-label">Địa điểm</span>
                            <span class="meta-value">
                                <i class="bi bi-geo-alt"></i>
                                @foreach (var loc in Model.Locations)
                                {
                                    <span>@loc.City </span>
                                }
                            </span>
                        </div>
                    </div>

                    <hr class="my-5" style="opacity: 0.1;">

                    <div class="mb-5">
                        <h4 class="section-title">Mô tả công việc</h4>
                        <ul class="content-list">
                            @foreach (var item in responsibilities)
                            {
                                <li>@item</li>
                            }
                        </ul>
                    </div>

                    <div class="mb-5">
                        <h4 class="section-title">Yêu cầu ứng viên</h4>
                        <ul class="content-list">
                            @foreach (var item in requirements)
                            {
                                <li>@item</li>
                            }
                        </ul>
                    </div>

                    <div class="mb-5">
                        <h4 class="section-title">Quyền lợi được hưởng</h4>
                        <div class="pt-2">
                            @foreach (var b in benefits)
                            {
                                <span class="benefit-tag">@b</span>
                            }
                        </div>
                    </div>

                    @if (Model.BusinessAccount != null)
                    {
                        <div class="mt-5 p-4 rounded-4" style="background: #f8fafc; border: 1px dashed #cbd5e1;">
                            <h5 class="fw-bold mb-2">Về @Model.Company</h5>
                            <p class="text-muted small mb-0">Lĩnh vực: @Model.BusinessAccount.Industry</p>
                        </div>
                    }
                </div>
            </div>

            <div class="col-lg-4">
                <div class="sticky-sidebar">
                    <div class="action-card mb-4">
                        <h6 class="fw-bold mb-3">Ứng tuyển công việc này</h6>
                        <button class="btn btn-apply-now mb-3">Ứng tuyển ngay</button>
                        <button class="btn btn-outline-primary w-100 rounded-3 fw-bold py-2">
                            <i class="bi bi-bookmark me-1"></i> Lưu tin này
                        </button>

                        @if (!string.IsNullOrEmpty(Model.OriginalUrl))
                        {
                            <a href="@Model.OriginalUrl" target="_blank" class="btn-secondary-custom">
                                <i class="bi bi-box-arrow-up-right me-2"></i>Xem link gốc
                            </a>
                        }
                    </div>

                    <div class="action-card">
                        <h6 class="fw-bold mb-3">Thông tin liên hệ</h6>
                        <div class="d-flex align-items-center gap-2 mb-2 small">
                            <i class="bi bi-telephone-outbound text-primary"></i>
                            <span class="text-muted">Liên hệ qua bộ phận nhân sự</span>
                        </div>
                        <div class="d-flex align-items-center gap-2 small">
                            <i class="bi bi-shield-check text-success"></i>
                            <span class="text-muted">Tin tuyển dụng đã xác thực</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <footer class="py-5 text-center text-muted small">
        &copy; 2026 Aris Skyve - Career Opportunities
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>