@model ArisSkyve.Domain.Entities.User
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Profile - Aris Platform</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <style>
        body { background: #f4f6fb; }
        .navbar { background: linear-gradient(90deg,#1e88e5,#42a5f5); }
        .logo { font-weight: 700; font-size: 22px; color: white; }
        .card { border: none; border-radius: 14px; box-shadow: 0 4px 14px rgba(0,0,0,0.06); margin-bottom: 20px; }
        .profile-cover { height: 150px; background: linear-gradient(90deg,#4facfe,#00f2fe); border-radius: 14px 14px 0 0; }
        .avatar-large { width: 120px; height: 120px; border-radius: 50%; border: 5px solid white; margin-top: -60px; background: white;}
        .section-title { font-weight: 600; color: #333; margin-bottom: 15px; border-bottom: 2px solid #eef3ff; padding-bottom: 8px; }
        .skill-badge { background-color: #eef3ff; color: #1e88e5; font-weight: 500; padding: 6px 12px; border-radius: 20px; display: inline-block; margin: 0 5px 5px 0; font-size: 13px; }
        .info-block h6 { font-weight: 700; color: #333; }
        .info-block i { font-size: 24px; }
    </style>
</head>
<body>

    <nav class="navbar d-flex navbar-expand-lg navbar-dark mb-4">
        <div class="container d-flex justify-content-between">
            <div class="logo">Aris</div>
            <a href="/Dashboard" class="btn btn-light btn-sm fw-bold text-primary"><i class="bi bi-arrow-left"></i> Back to Dashboard</a>
        </div>
    </nav>

    <div class="container pb-5">
        <div class="row">
            <div class="col-lg-4">

                <div class="card text-center mb-4 position-relative">
                    <button class="btn btn-sm btn-light position-absolute top-0 end-0 m-2 shadow-sm" style="z-index: 10; border-radius:50%;" data-bs-toggle="modal" data-bs-target="#editBasicInfoModal" title="Sửa thông tin"><i class="bi bi-pencil"></i></button>

                    <div class="profile-cover"></div>
                    <div class="card-body">
                        <img src="@(Model.AvatarUrl ?? "https://i.pravatar.cc/150")" class="avatar-large mb-3 object-fit-cover">
                        <h4 class="mb-1 fw-bold">@Model.employesAccount.fullName</h4>
                        <p class="text-muted mb-2">@(Model.employesAccount.Headline ?? "Chưa cập nhật chức danh")</p>
                        <p class="small text-muted"><i class="bi bi-geo-alt"></i> @(Model.employesAccount.Location ?? "Chưa cập nhật địa điểm")</p>

                        <div class="row g-2 mt-2">
                            <div class="col-6">
                                <button class="btn btn-primary btn-sm w-100" data-bs-toggle="modal" data-bs-target="#uploadCvModal">
                                    <i class="bi bi-cloud-upload"></i> @(string.IsNullOrEmpty(Model.employesAccount.ResumeUrl) ? "Upload CV" : "Sửa CV")
                                </button>
                                @if (!string.IsNullOrEmpty(Model.employesAccount.ResumeUrl))
                                {
                                    <a href="@Model.employesAccount.ResumeUrl" target="_blank" class="d-block text-center mt-1 small">Xem CV</a>
                                }
                            </div>
                            <div class="col-6">
                                @if (!string.IsNullOrEmpty(Model.employesAccount.PersonalLink))
                                {
                                    <a href="@Model.employesAccount.PersonalLink" target="_blank" class="btn btn-outline-secondary btn-sm w-100"><i class="bi bi-link-45deg"></i> Portfolio</a>
                                    <a href="#" class="d-block text-center mt-1 small text-muted" data-bs-toggle="modal" data-bs-target="#editPortfolioModal">Đổi Link</a>
                                }
                                else
                                {
                                    <button class="btn btn-outline-secondary btn-sm w-100" data-bs-toggle="modal" data-bs-target="#editPortfolioModal"><i class="bi bi-link-45deg"></i> + Link</button>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card p-3 mb-4">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h6 class="section-title mb-0 border-0 fw-bold">Ngoại ngữ</h6>
                        <button class="btn btn-xs btn-outline-primary p-1 py-0" data-bs-toggle="modal" data-bs-target="#addLanguageModal"><i class="bi bi-plus"></i></button>
                    </div>
                    <div class="small">
                        @if (Model.employesAccount.Languages != null && Model.employesAccount.Languages.Any())
                        {
                            foreach (var lang in Model.employesAccount.Languages)
                            {
                                <div class="d-flex justify-content-between mb-1">
                                    <span class="fw-bold">@lang.Name</span>
                                    <span class="text-muted">@lang.Proficiency</span>
                                </div>
                            }
                        }
                        else
                        {
                            <span class="text-muted">Chưa có ngoại ngữ.</span>
                        }
                    </div>
                </div>

                <div class="card p-3">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h6 class="section-title mb-0 border-0 fw-bold">Kỹ năng (Skills)</h6>
                        <button class="btn btn-xs btn-outline-primary p-1 py-0" data-bs-toggle="modal" data-bs-target="#addSkillModal"><i class="bi bi-plus"></i></button>
                    </div>
                    <div>
                        @if (Model.employesAccount.Skills != null && Model.employesAccount.Skills.Any())
                        {
                            foreach (var skill in Model.employesAccount.Skills)
                            {
                                <span class="skill-badge">@skill.Name</span>
                            }
                        }
                        else
                        {
                            <span class="text-muted small">Chưa có kỹ năng nào.</span>
                        }
                    </div>
                </div>

            </div>

            <div class="col-lg-8">

                <div class="card p-4 mb-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="section-title mb-0 border-0 fw-bold">Giới thiệu bản thân</h5>
                        <button class="btn btn-sm btn-light p-1 py-0" data-bs-toggle="modal" data-bs-target="#editAboutMeModal"><i class="bi bi-pencil"></i> Sửa</button>
                    </div>
                    <p class="text-muted small" style="white-space: pre-wrap;">@(Model.employesAccount.AboutMe ?? "Hãy thêm vài dòng giới thiệu về bản thân bạn để nhà tuyển dụng hiểu rõ hơn.")</p>
                </div>

                <div class="row mt-4">

                    <div class="col-md-6 mb-4">
                        <div class="card p-3 info-block">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h6 class="section-title mb-0 border-0 fs-6">Kinh nghiệm dự án</h6>
                                <button class="btn btn-xs btn-primary p-1 py-0" data-bs-toggle="modal" data-bs-target="#addExperienceModal"><i class="bi bi-plus"></i></button>
                            </div>
                            @if (Model.employesAccount.Experiences != null && Model.employesAccount.Experiences.Any())
                            {
                                foreach (var exp in Model.employesAccount.Experiences)
                                {
                                    <div class="d-flex mb-3 align-items-start">
                                        <i class="bi bi-briefcase-fill text-primary me-3 mt-1"></i>
                                        <div>
                                            <h6 class="mb-0 small fw-bold">@exp.CompanyName</h6>
                                            <p class="text-muted xx-small mb-1">@exp.Position | @exp.StartDate.ToString("MM/yyyy") - @(exp.EndDate?.ToString("MM/yyyy") ?? "Hiện tại")</p>
                                            <p class="small mb-0">@exp.Description</p>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <p class="text-muted small">Chưa có kinh nghiệm.</p>
                            }
                        </div>
                    </div>

                    <div class="col-md-6 mb-4">
                        <div class="card p-3 info-block">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h6 class="section-title mb-0 border-0 fs-6">Học vấn & bằng cấp</h6>
                                <button class="btn btn-xs btn-primary p-1 py-0" data-bs-toggle="modal" data-bs-target="#addEducationModal"><i class="bi bi-plus"></i></button>
                            </div>
                            @if (Model.employesAccount.Educations != null && Model.employesAccount.Educations.Any())
                            {
                                foreach (var edu in Model.employesAccount.Educations)
                                {
                                    <div class="d-flex mb-3 align-items-start">
                                        <i class="bi bi-mortarboard-fill text-warning me-3 mt-1"></i>
                                        <div>
                                            <h6 class="mb-0 small fw-bold">@edu.SchoolName</h6>
                                            <p class="text-muted xx-small mb-0">@edu.Degree - @edu.FieldOfStudy</p>
                                            <p class="text-muted xx-small mb-0">@edu.StartDate.ToString("yyyy") - @(edu.EndDate?.ToString("yyyy") ?? "Hiện tại")</p>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <p class="text-muted small">Chưa có học vấn.</p>
                            }
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <div class="modal fade" id="editBasicInfoModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content border-0" style="border-radius: 14px;">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold">Chỉnh sửa thông tin</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form action="/Profile/UpdateBasicInfo" method="post">
                    <input type="hidden" name="aboutMe" value="@Model.employesAccount.AboutMe" />
                    <input type="hidden" name="personalLink" value="@Model.employesAccount.PersonalLink" />
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label text-muted small fw-bold">Họ và Tên</label>
                            <input type="text" class="form-control" name="fullName" value="@Model.employesAccount.fullName" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label text-muted small fw-bold">Chức danh (Headline)</label>
                            <input type="text" class="form-control" name="headline" value="@Model.employesAccount.Headline" placeholder="VD: Backend Developer">
                        </div>
                        <div class="mb-3">
                            <label class="form-label text-muted small fw-bold">Địa điểm</label>
                            <input type="text" class="form-control" name="location" value="@Model.employesAccount.Location" placeholder="VD: Hải Phòng">
                        </div>
                    </div>
                    <div class="modal-footer border-0 pt-0">
                        <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="editAboutMeModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content border-0" style="border-radius: 14px;">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold">Giới thiệu bản thân</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form action="/Profile/UpdateBasicInfo" method="post">
                    <input type="hidden" name="fullName" value="@Model.employesAccount.fullName" />
                    <input type="hidden" name="headline" value="@Model.employesAccount.Headline" />
                    <input type="hidden" name="location" value="@Model.employesAccount.Location" />
                    <input type="hidden" name="personalLink" value="@Model.employesAccount.PersonalLink" />
                    <div class="modal-body">
                        <textarea class="form-control" name="aboutMe" rows="5" placeholder="Viết vài dòng giới thiệu về bản thân...">@Model.employesAccount.AboutMe</textarea>
                    </div>
                    <div class="modal-footer border-0 pt-0">
                        <button type="submit" class="btn btn-primary">Lưu Giới thiệu</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="editPortfolioModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-sm modal-dialog-centered">
            <div class="modal-content border-0" style="border-radius: 14px;">
                <div class="modal-header border-0 pb-0">
                    <h6 class="modal-title fw-bold">Link Portfolio / GitHub</h6>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form action="/Profile/UpdateBasicInfo" method="post">
                    <input type="hidden" name="fullName" value="@Model.employesAccount.fullName" />
                    <input type="hidden" name="headline" value="@Model.employesAccount.Headline" />
                    <input type="hidden" name="location" value="@Model.employesAccount.Location" />
                    <input type="hidden" name="aboutMe" value="@Model.employesAccount.AboutMe" />
                    <div class="modal-body pb-1">
                        <input type="text" class="form-control" name="personalLink" value="@Model.employesAccount.PersonalLink" placeholder="https://github.com/..." required>
                    </div>
                    <div class="modal-footer border-0 pt-2">
                        <button type="submit" class="btn btn-primary btn-sm w-100">Lưu Link</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="addLanguageModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-sm modal-dialog-centered">
            <div class="modal-content border-0" style="border-radius: 14px;">
                <div class="modal-header border-0 pb-0">
                    <h6 class="modal-title fw-bold">Thêm Ngoại ngữ</h6>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form action="/Profile/AddLanguage" method="post">
                    <div class="modal-body pb-1">
                        <input type="text" class="form-control mb-2" name="Name" placeholder="Tên (VD: Tiếng Anh)" required>
                        <input type="text" class="form-control" name="Proficiency" placeholder="Trình độ (VD: IELTS 7.0)" required>
                    </div>
                    <div class="modal-footer border-0 pt-2">
                        <button type="submit" class="btn btn-primary btn-sm w-100">Lưu</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="addSkillModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-sm modal-dialog-centered">
            <div class="modal-content border-0" style="border-radius: 14px;">
                <div class="modal-header border-0 pb-0">
                    <h6 class="modal-title fw-bold">Thêm Kỹ năng</h6>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form action="/Profile/AddSkill" method="post">
                    <div class="modal-body pb-1">
                        <input type="text" class="form-control" name="skillName" placeholder="VD: C#, ReactJS..." required>
                    </div>
                    <div class="modal-footer border-0 pt-2">
                        <button type="submit" class="btn btn-primary btn-sm w-100">Thêm</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="addExperienceModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content border-0" style="border-radius: 14px;">
                <div class="modal-header border-0 pb-0">
                    <h6 class="modal-title fw-bold">Thêm Kinh nghiệm</h6>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form action="/Profile/AddExperience" method="post">
                    <div class="modal-body pb-1">
                        <input type="text" class="form-control mb-2" name="CompanyName" placeholder="Tên công ty / Dự án" required>
                        <input type="text" class="form-control mb-2" name="Position" placeholder="Vị trí (VD: Backend Dev)" required>
                        <div class="row g-2 mb-2">
                            <div class="col-6"><input type="month" class="form-control text-muted" name="StartDate" required></div>
                            <div class="col-6"><input type="month" class="form-control text-muted" name="EndDate"></div>
                        </div>
                        <textarea class="form-control" name="Description" rows="3" placeholder="Mô tả công việc..."></textarea>
                    </div>
                    <div class="modal-footer border-0 pt-2">
                        <button type="submit" class="btn btn-primary btn-sm w-100">Lưu Kinh nghiệm</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="addEducationModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content border-0" style="border-radius: 14px;">
                <div class="modal-header border-0 pb-0">
                    <h6 class="modal-title fw-bold">Thêm Học vấn</h6>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form action="/Profile/AddEducation" method="post">
                    <div class="modal-body pb-1">
                        <input type="text" class="form-control mb-2" name="SchoolName" placeholder="Tên trường" required>
                        <div class="row g-2 mb-2">
                            <div class="col-6"><input type="text" class="form-control" name="Degree" placeholder="Bằng cấp (VD: Cử nhân)"></div>
                            <div class="col-6"><input type="text" class="form-control" name="FieldOfStudy" placeholder="Chuyên ngành"></div>
                        </div>
                        <div class="row g-2 mb-2">
                            <div class="col-6"><input type="month" class="form-control text-muted" name="StartDate" required></div>
                            <div class="col-6"><input type="month" class="form-control text-muted" name="EndDate"></div>
                        </div>
                    </div>
                    <div class="modal-footer border-0 pt-2">
                        <button type="submit" class="btn btn-primary btn-sm w-100">Lưu Học vấn</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="uploadCvModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-sm modal-dialog-centered">
            <div class="modal-content border-0" style="border-radius: 14px;">
                <div class="modal-header border-0 pb-0">
                    <h6 class="modal-title fw-bold">Tải lên CV</h6>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form action="/Profile/UploadCV" method="post" enctype="multipart/form-data">
                    <div class="modal-body pb-1">
                        <input type="file" class="form-control text-muted small" name="cvFile" accept=".pdf,.doc,.docx" required>
                    </div>
                    <div class="modal-footer border-0 pt-2">
                        <button type="submit" class="btn btn-primary btn-sm w-100"><i class="bi bi-cloud-upload"></i> Lưu CV</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>