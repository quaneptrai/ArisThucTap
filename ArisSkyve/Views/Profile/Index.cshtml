@{
    Layout = null;
}
<!DOCTYPE html>
    <html>
    <head>
        <title>Profile</title>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <style>
        .cover {
            width: 100%;
            height: 300px;
            background: linear-gradient(to bottom, #ccc, #999);
            border-radius: 10px;
            position: relative;
        }

        .toolstab {
            position: absolute;
            bottom: 10px;
            right: 10px;
        }

        .navbar {
            background: linear-gradient(90deg,#1e88e5,#42a5f5)
        }

            .navbar .nav-link {
                position: relative;
                padding-bottom: 8px;
            }

                .navbar .nav-link::after {
                    content: "";
                    position: absolute;
                    left: 0;
                    bottom: 0;
                    width: 0;
                    height: 3px;
                    background: white;
                    transition: width 0.25s ease;
                }

                .navbar .nav-link:hover::after {
                    width: 100%;
                }
        .logo{
            text-decoration: none;
            font-size: 24px;
            color: white;
        }

        .profileInfor{
            margin-left: 50px;
        }
        .profileInfor .avatar {
            width: 200px;
            height: 200px;
            border-radius: 50%;
            border: 3px solid #fff;
            }
    </style> 
    </head>
    <body class="bg-light">
    <nav class="navbar d-flex navbar-expand-lg navbar-dark">
        <div class="container-fluid d-flex justify-content-between">
            <div class="rightHeaderBar">
                <a asp-controller="Dashboard" asp-action="Index" class="logo">Aris</a>
            </div>
            <div class="rightHeaderBar ms-auto pe-3">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link text-light d-flex flex-column align-items-center">
                            <i class="bi bi-house fs-6"></i>
                            <span>Home</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-light d-flex flex-column align-items-center">
                            <i class="bi bi-people fs-6"></i>
                            <span>Network</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-light d-flex flex-column align-items-center">
                            <i class="bi bi-briefcase fs-6"></i>
                            <span>Jobs</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-light d-flex flex-column align-items-center">
                            <i class="bi bi-bell fs-6"></i>
                            <span>Notifications</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-light d-flex flex-column align-items-center">
                            <i class="bi bi-gear fs-6"></i>
                            <span>Settings</span>
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
        <div class="container mt-2">
            <div class="cover">
                <div class="toolstab">
                    <button class="btn btn-light">
                    <i class="bi bi-camera-fill"></i> Add cover photo
                    </button>
                </div>
            </div>
        <div class="profileInfor">
            <img src="https://i.pravatar.cc/300" class="avatar">
        </div>
        </div>
    </body>
    </html>